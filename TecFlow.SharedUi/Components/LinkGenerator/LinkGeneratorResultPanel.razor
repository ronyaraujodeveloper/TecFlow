@using TecFlow.Business.Dto
@inject IJSRuntime Js

@if (Response is { Success: true } response && !string.IsNullOrWhiteSpace(response.ShortenedUrl))
{
    <section id="link-generator-result"
             class="link-generator-result card border-0 shadow-sm mt-4"
             role="region"
             aria-live="polite"
             aria-label="Link de comissão gerado">
        <div class="card-body p-3 p-md-4">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
                <div>
                    <span class="link-generator-result-badge">Link pronto</span>
                    <h2 class="h5 fw-bold mb-1 mt-2">Seu link de comissão</h2>
                    @if (!string.IsNullOrWhiteSpace(response.PlatformDetected))
                    {
                        <p class="text-muted small mb-0">
                            Plataforma: <strong>@response.PlatformDetected</strong>
                        </p>
                    }
                </div>
                <span class="link-generator-result-check" aria-hidden="true">✓</span>
            </div>

            <label class="form-label small text-muted mb-1" for="generated-short-url">
                URL encurtada TecFlow
            </label>
            <div class="link-generator-result-url-wrap">
                <output id="generated-short-url"
                        class="link-generator-result-url font-monospace"
                        for="product-url">
                    @response.ShortenedUrl
                </output>
            </div>

            <div class="link-generator-result-actions d-grid d-sm-flex gap-2 mt-4">
                <button type="button"
                        class="btn btn-lg btn-touch flex-fill @(_copied ? "btn-success" : "btn-outline-primary")"
                        disabled="@_isCopying"
                        aria-live="polite"
                        @onclick="CopyLinkAsync">
                    @if (_copied)
                    {
                        <span>Copiado!</span>
                    }
                    else
                    {
                        <span>Copiar Link</span>
                    }
                </button>

                <button type="button"
                        class="btn btn-primary btn-lg btn-touch flex-fill link-generator-share-btn"
                        disabled="@_isSharing"
                        @onclick="ShareLinkAsync">
                    <svg class="link-generator-share-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92-1.31-2.92-2.92-2.92z" />
                    </svg>
                    <span>@(_isSharing ? "Abrindo..." : "Compartilhar")</span>
                </button>
            </div>

            @if (!string.IsNullOrWhiteSpace(_actionMessage))
            {
                <p class="small mt-3 mb-0 @(_actionIsError ? "text-danger" : "text-success")" role="status">
                    @_actionMessage
                </p>
            }
        </div>
    </section>
}

@code {
    [Parameter, EditorRequired] public GerarLinkAfiliadoResponseDto? Response { get; set; }

    private bool _copied;
    private bool _isCopying;
    private bool _isSharing;
    private string? _actionMessage;
    private bool _actionIsError;

    protected override void OnParametersSet()
    {
        if (Response?.ShortenedUrl is null)
        {
            ResetActionState();
        }
    }

    private async Task CopyLinkAsync()
    {
        if (Response?.ShortenedUrl is not { Length: > 0 } url)
        {
            return;
        }

        _isCopying = true;
        _actionMessage = null;

        try
        {
            var copied = await Js.InvokeAsync<bool>("tecFlowAppInterop.copyToClipboard", url);
            if (copied)
            {
                _copied = true;
                _actionIsError = false;
                _actionMessage = "Link copiado para a área de transferência.";
                StateHasChanged();
                await Task.Delay(2200);
                _copied = false;
                _actionMessage = null;
            }
            else
            {
                _actionIsError = true;
                _actionMessage = "Não foi possível copiar o link. Tente selecionar e copiar manualmente.";
            }
        }
        catch (Exception)
        {
            _actionIsError = true;
            _actionMessage = "Erro ao copiar o link.";
        }
        finally
        {
            _isCopying = false;
            StateHasChanged();
        }
    }

    private async Task ShareLinkAsync()
    {
        if (Response?.ShortenedUrl is not { Length: > 0 } url)
        {
            return;
        }

        _isSharing = true;
        _actionMessage = null;

        try
        {
            var shareText = string.IsNullOrWhiteSpace(Response.PlatformDetected)
                ? "Confira este produto com meu link de comissão TecFlow:"
                : $"Confira este produto na {Response.PlatformDetected} com meu link de comissão:";

            var result = await Js.InvokeAsync<ShareLinkResult>(
                "tecFlowAppInterop.shareLink",
                "TecFlow — Link de Comissão",
                shareText,
                url);

            if (result.Cancelled)
            {
                return;
            }

            if (result.Success)
            {
                _actionIsError = false;
                _actionMessage = result.Method switch
                {
                    "whatsapp" => "Abrimos o WhatsApp Web com a mensagem pronta para envio.",
                    _ => "Compartilhamento iniciado no dispositivo."
                };
            }
            else
            {
                _actionIsError = true;
                _actionMessage = "Não foi possível abrir o compartilhamento.";
            }
        }
        catch (Exception)
        {
            _actionIsError = true;
            _actionMessage = "Erro ao compartilhar o link.";
        }
        finally
        {
            _isSharing = false;
            StateHasChanged();
        }
    }

    private void ResetActionState()
    {
        _copied = false;
        _isCopying = false;
        _isSharing = false;
        _actionMessage = null;
        _actionIsError = false;
    }

    private sealed class ShareLinkResult
    {
        public bool Success { get; set; }
        public bool Cancelled { get; set; }
        public string? Method { get; set; }
    }
}
