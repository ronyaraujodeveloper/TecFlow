@using TecFlow.SharedUi.Extensions

<Router AppAssembly="typeof(Program).Assembly" AdditionalAssemblies="new[] { typeof(ServiceCollectionExtensions).Assembly }">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(TecFlow.SharedUi.Components.Layout.MainLayout)">
            <NotAuthorized>
                @if (context.User.Identity?.IsAuthenticated != true)
                {
                    <RedirectToLogin />
                }
                else
                {
                    <p role="alert" class="alert alert-warning">N„o tem permiss„o para aceder a esta p·gina.</p>
                }
            </NotAuthorized>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>
