@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<PageTitle>TecFlow — Entrar</PageTitle>

<div class="login-page unified-login-page">
    <div class="unified-login-shell mx-auto">
        <header class="text-center mb-4 mb-md-5">
            <span class="brand-badge">TecFlow</span>
            <h1 class="display-6 fw-bold mt-3 mb-2">Bem-vindo de volta</h1>
            <p class="lead text-muted mx-auto unified-login-lead">
                Automação de afiliados com login unificado. Conecte-se e gerencie suas campanhas em um só lugar.
            </p>
        </header>

        <UnifiedLoginCard />
    </div>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            Navigation.NavigateTo("/dashboard", replace: true);
        }
    }
}
