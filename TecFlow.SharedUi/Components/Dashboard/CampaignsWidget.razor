@using System.Globalization

<div class="card border-0 shadow-sm" id="campanhas">
    <div class="card-header bg-white border-0 pt-3 px-3 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="h6 fw-semibold mb-0">Campanhas</h2>
            @if (Response is { Status: true })
            {
                <span class="small text-muted">@Response.Descricao</span>
            }
        </div>
        <span class="badge text-bg-light text-dark">@(Items.Count)</span>
    </div>
    <div class="card-body p-0">
        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="p-3">
                <p class="text-danger small mb-0">@ErrorMessage</p>
            </div>
        }
        else if (Items.Count == 0)
        {
            <div class="p-4 text-center text-muted">
                <p class="mb-0">Nenhuma campanha registada para os filtros aplicados.</p>
            </div>
        }
        else
        {
            <div class="responsive-data-table">
                <div class="data-cards-mobile">
                    @foreach (var campaign in Items)
                    {
                        <article class="data-list-card">
                            <div class="data-list-card-header">
                                <h3 class="data-list-card-title">@campaign.Name</h3>
                                @RenderCampaignStatus(campaign)
                            </div>
                            @if (!string.IsNullOrWhiteSpace(campaign.Description))
                            {
                                <p class="small text-muted mb-2">@campaign.Description</p>
                            }
                            <dl>
                                <dt>Período</dt>
                                <dd>
                                    @campaign.StartDate.ToString("d", PtBr)
                                    —
                                    @campaign.EndDate.ToString("d", PtBr)
                                </dd>
                                <dt>Orçamento</dt>
                                <dd>@campaign.Budget.ToString("C2", PtBr)</dd>
                            </dl>
                        </article>
                    }
                </div>

                <div class="data-table-desktop table-responsive">
                    <table class="table table-hover align-middle mb-0 dashboard-table">
                        <thead class="table-light">
                            <tr>
                                <th>Nome</th>
                                <th>Período</th>
                                <th class="text-end">Orçamento</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var campaign in Items)
                            {
                                <tr>
                                    <td>
                                        <span class="fw-medium">@campaign.Name</span>
                                        @if (!string.IsNullOrWhiteSpace(campaign.Description))
                                        {
                                            <br />
                                            <span class="small text-muted">@campaign.Description</span>
                                        }
                                    </td>
                                    <td class="small text-nowrap">
                                        @campaign.StartDate.ToString("d", PtBr)
                                        —
                                        @campaign.EndDate.ToString("d", PtBr)
                                    </td>
                                    <td class="text-end text-nowrap">@campaign.Budget.ToString("C2", PtBr)</td>
                                    <td>@RenderCampaignStatus(campaign)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @if (Response?.Paging is { } paging)
            {
                <div class="px-3 py-2 border-top small text-muted">
                    Página @paging.CurrentPage de @(paging.TotalPages == 0 ? 1 : paging.TotalPages)
                    · @paging.TotalCount registo(s)
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter] public CampaignResponseDto? Response { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }

    private IReadOnlyList<Campaign> Items =>
        Response?.DataList?.OrderByDescending(c => c.StartDate).ToList() ?? [];

    private static readonly CultureInfo PtBr = CultureInfo.GetCultureInfo("pt-BR");

    private static MarkupString RenderCampaignStatus(Campaign campaign)
    {
        if (campaign.IsActive())
        {
            return new MarkupString("""<span class="badge text-bg-success">Ativa</span>""");
        }

        if (campaign.EndDate < DateTime.UtcNow)
        {
            return new MarkupString("""<span class="badge text-bg-secondary">Encerrada</span>""");
        }

        return new MarkupString("""<span class="badge text-bg-warning text-dark">Agendada</span>""");
    }
}
