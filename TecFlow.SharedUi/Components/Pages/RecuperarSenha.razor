@page "/recuperar-senha"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<PageTitle>TecFlow — Recuperar ou alterar senha</PageTitle>

<div class="login-page d-flex justify-content-center">
    <div class="w-100 unified-login-shell">
        <div class="text-center mb-4">
            <a href="/" class="text-decoration-none text-muted small d-inline-flex align-items-center gap-1">
                &larr; Voltar ao login
            </a>
            <h1 class="h3 fw-bold mt-3 mb-2">Recuperar ou alterar senha</h1>
            <p class="text-muted small mb-0 mx-auto" style="max-width: 28rem;">
                Gerencie o acesso à sua conta TecFlow de forma segura.
            </p>
        </div>

        <AuthorizeView>
            <Authorized>
                <div class="card shadow-sm border-0 login-card unified-login-card">
                    <div class="card-body p-4">
                        <h2 class="h5 fw-semibold mb-2">Alterar senha</h2>
                        <p class="text-muted small mb-4">
                            Você já está autenticado. Em breve, a central de segurança permitirá alterar a senha diretamente aqui.
                        </p>
                        <a href="/dashboard" class="btn btn-primary btn-lg w-100 btn-touch">
                            Ir para o painel
                        </a>
                    </div>
                </div>
            </Authorized>
            <NotAuthorized Context="authContext">
                <div class="card shadow-sm border-0 login-card unified-login-card">
                    <div class="card-body p-4">
                        <h2 class="h5 fw-semibold mb-2">Esqueci minha senha</h2>
                        <p class="text-muted small mb-4">
                            Informe o e-mail cadastrado. Enviaremos instruções quando a recuperação automática estiver disponível.
                        </p>

                        <EditForm Model="_recoveryModel" OnValidSubmit="SubmitRecoveryRequestAsync">
                            <DataAnnotationsValidator />

                            <div class="mb-3">
                                <label class="form-label fw-semibold" for="recovery-email">E-mail</label>
                                <InputText id="recovery-email"
                                           class="form-control form-control-lg"
                                           @bind-Value="_recoveryModel.Email"
                                           placeholder="seu@email.com"
                                           autocomplete="email"
                                           inputmode="email" />
                                <ValidationMessage For="@(() => _recoveryModel.Email)" />
                            </div>

                            @if (!string.IsNullOrWhiteSpace(_feedbackMessage))
                            {
                                <div class="alert @(_feedbackIsError ? "alert-danger" : "alert-info") small py-2" role="status">
                                    @_feedbackMessage
                                </div>
                            }

                            <button type="submit" class="btn btn-outline-primary btn-lg w-100 btn-touch">
                                Enviar instruções
                            </button>
                        </EditForm>
                    </div>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</div>

@code {
    private readonly RecoveryModel _recoveryModel = new();
    private string? _feedbackMessage;
    private bool _feedbackIsError;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            return;
        }
    }

    private Task SubmitRecoveryRequestAsync()
    {
        _feedbackIsError = false;
        _feedbackMessage =
            "Recebemos sua solicitação. A recuperação automática de senha será habilitada em breve. " +
            "Se precisar de acesso imediato, entre em contato com o suporte TecFlow.";

        return Task.CompletedTask;
    }

    private sealed class RecoveryModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "E-mail é obrigatório.")]
        [ValidEmail(ErrorMessage = "E-mail inválido.")]
        public string Email { get; set; } = string.Empty;
    }
}
