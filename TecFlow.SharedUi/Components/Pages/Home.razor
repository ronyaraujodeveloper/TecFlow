@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<PageTitle>TecFlow ? Entrar</PageTitle>

<div class="home-hero text-center">
    <div class="mb-4">
        <span class="brand-badge">TecFlow</span>
        <h1 class="display-5 fw-bold mt-3">Automação de afiliados</h1>
        <p class="lead text-muted mx-auto" style="max-width: 32rem;">
            Conecte a sua conta e comece a orquestrar campanhas nas principais plataformas.
        </p>
    </div>

    <div class="row g-4 justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card platform-card h-100 border-0 shadow-sm">
                <div class="card-body d-flex flex-column p-4">
                    <div class="platform-icon tiktok mb-3">?</div>
                    <h2 class="h4 fw-semibold">TikTok</h2>
                    <p class="text-muted flex-grow-1">Shop, Ads e publicação automatizada.</p>
                    <a href="/login/tiktok" class="btn btn-dark btn-lg w-100 mt-2 btn-touch">
                        Entrar com TikTok
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-5 col-lg-4">
            <div class="card platform-card h-100 border-0 shadow-sm">
                <div class="card-body d-flex flex-column p-4">
                    <div class="platform-icon shopee mb-3">S</div>
                    <h2 class="h4 fw-semibold">Shopee</h2>
                    <p class="text-muted flex-grow-1">Produtos afiliados e métricas em tempo real.</p>
                    <a href="/login/shopee" class="btn btn-warning btn-lg w-100 mt-2 text-dark fw-semibold btn-touch">
                        Entrar com Shopee
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            Navigation.NavigateTo("/dashboard", replace: true);
        }
    }
}
