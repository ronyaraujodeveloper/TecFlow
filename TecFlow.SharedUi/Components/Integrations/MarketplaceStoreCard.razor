@using TecFlow.Core.Enums
@using TecFlow.Database.Entity

<div class="marketplace-store-card card border-0 shadow-sm h-100">
    <div class="card-body d-flex flex-column gap-3">
        <div class="d-flex align-items-start justify-content-between gap-2">
            <div class="min-w-0">
                <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                    <span class="marketplace-platform-badge @GetPlatformBadgeClass()">@GetPlatformLabel()</span>
                    <span class="badge @GetStatusBadgeClass()">@GetStatusLabel()</span>
                </div>
                <h3 class="h6 fw-semibold mb-1 text-truncate" title="@Store.FriendlyName">@Store.FriendlyName</h3>
                <p class="text-muted small mb-0">Shop ID: <span class="font-monospace">@Store.ShopId</span></p>
            </div>
        </div>

        <dl class="marketplace-store-meta mb-0">
            <div>
                <dt>Vinculada em</dt>
                <dd>@Store.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
            </div>
            <div>
                <dt>Token expira em</dt>
                <dd>@Store.ExpiresAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
            </div>
        </dl>

        <div class="marketplace-store-actions mt-auto d-grid">
            @if (_confirmDelete)
            {
                <p class="text-danger small mb-2">Confirmar desconexão desta loja?</p>
                <div class="d-grid gap-2">
                    <button type="button" class="btn btn-danger btn-touch" disabled="@IsBusy" @onclick="ConfirmDeleteAsync">
                        Sim, desconectar
                    </button>
                    <button type="button" class="btn btn-outline-secondary btn-touch" disabled="@IsBusy" @onclick="CancelDelete">
                        Cancelar
                    </button>
                </div>
            }
            else
            {
                <button type="button"
                        class="btn btn-outline-danger btn-touch"
                        disabled="@IsBusy"
                        @onclick="RequestDelete">
                    Desconectar loja
                </button>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public IntegracaoLoja Store { get; set; } = default!;
    [Parameter] public bool IsBusy { get; set; }
    [Parameter] public EventCallback<int> OnUnlink { get; set; }

    private bool _confirmDelete;

    private string GetPlatformLabel() => Store.PlatformType switch
    {
        MarketplaceType.TikTokShop => "TikTok Shop",
        MarketplaceType.Shopee => "Shopee",
        _ => Store.PlatformType.ToString()
    };

    private string GetPlatformBadgeClass() => Store.PlatformType switch
    {
        MarketplaceType.TikTokShop => "marketplace-platform-badge--tiktok",
        MarketplaceType.Shopee => "marketplace-platform-badge--shopee",
        _ => string.Empty
    };

    private string GetStatusLabel() => Store.Status switch
    {
        MarketplaceIntegrationStatus.Active => "Ativo",
        MarketplaceIntegrationStatus.Expired => "Expirado",
        MarketplaceIntegrationStatus.Inactive => "Inativo",
        _ => Store.Status.ToString()
    };

    private string GetStatusBadgeClass() => Store.Status switch
    {
        MarketplaceIntegrationStatus.Active => "text-bg-success",
        MarketplaceIntegrationStatus.Expired => "text-bg-warning",
        MarketplaceIntegrationStatus.Inactive => "text-bg-secondary",
        _ => "text-bg-secondary"
    };

    private void RequestDelete() => _confirmDelete = true;

    private void CancelDelete() => _confirmDelete = false;

    private async Task ConfirmDeleteAsync()
    {
        await OnUnlink.InvokeAsync(Store.Id);
        _confirmDelete = false;
    }
}
