@using TecFlow.WebUi.Models.Responses

<div class="card border-0 shadow-sm h-100">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <h2 class="h6 fw-semibold mb-0">Pipeline Orquestrador</h2>
            @if (Status is not null)
            {
                <span class="badge @GetStatusBadgeClass(Status.Status)">@Status.Status</span>
            }
        </div>

        @if (IsLoading)
        {
            <p class="text-muted small mb-0">A consultar estado...</p>
        }
        else if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <p class="text-danger small mb-0">@ErrorMessage</p>
        }
        else if (Status is null)
        {
            <p class="text-muted small mb-0">Estado indisponível.</p>
        }
        else
        {
            <p class="text-muted small mb-1">
                Última atualização:
                <time datetime="@Status.Timestamp.ToString("O")">
                    @Status.Timestamp.ToLocalTime().ToString("g")
                </time>
            </p>
            <p class="mb-0 small">
                O pipeline executa coleta, processamento, IA e publicação automática.
            </p>
        }
    </div>
</div>

@code {
    [Parameter] public PipelineStatusDto? Status { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }

    private static string GetStatusBadgeClass(string? status) => status?.ToLowerInvariant() switch
    {
        "running" or "executando" or "em execução" => "text-bg-primary",
        "completed" or "concluído" or "idle" or "ocioso" => "text-bg-success",
        "failed" or "erro" or "falhou" => "text-bg-danger",
        _ => "text-bg-secondary"
    };
}
