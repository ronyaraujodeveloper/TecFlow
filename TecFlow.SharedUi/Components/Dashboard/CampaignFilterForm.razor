<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-3">
        <div class="row g-2 align-items-end">
            <div class="col-12 col-md-4">
                <label class="form-label small mb-1" for="campaign-name-filter">Nome</label>
                <input id="campaign-name-filter"
                       class="form-control form-control-sm"
                       @bind="Filter.Name"
                       @bind:event="oninput"
                       placeholder="Filtrar por nome..." />
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label small mb-1" for="campaign-desc-filter">Descrição</label>
                <input id="campaign-desc-filter"
                       class="form-control form-control-sm"
                       @bind="Filter.Description"
                       @bind:event="oninput"
                       placeholder="Filtrar por descrição..." />
            </div>
            <div class="col-12 col-sm-6 col-md-2">
                <label class="form-label small mb-1" for="campaign-start-filter">Início a partir de</label>
                <InputDate id="campaign-start-filter"
                           class="form-control form-control-sm"
                           @bind-Value="Filter.StartDate"
                           TValue="DateTime?" />
            </div>
            <div class="col-12 col-md-2">
                <div class="filter-form-actions">
                    <button type="button" class="btn btn-primary" disabled="@IsBusy" @onclick="OnSearchClicked">
                        Buscar
                    </button>
                    <button type="button" class="btn btn-outline-secondary" disabled="@IsBusy" @onclick="OnClearClicked">
                        Limpar
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public CampaignFilter Filter { get; set; } = new();
    [Parameter] public bool IsBusy { get; set; }
    [Parameter] public EventCallback OnSearch { get; set; }
    [Parameter] public EventCallback OnClear { get; set; }

    private Task OnSearchClicked() => OnSearch.InvokeAsync();
    private Task OnClearClicked() => OnClear.InvokeAsync();
}
