@inherits LayoutComponentBase

<div class="portal-shell min-vh-100 d-flex flex-column">
    <header class="portal-header py-3">
        <div class="container d-flex align-items-center justify-content-between">
            <a href="/" class="navbar-brand fw-bold text-decoration-none text-dark">TecFlow Portal</a>
            <div class="d-flex align-items-center gap-2">
                <AuthorizeView>
                    <Authorized>
                        <a href="/dashboard" class="btn btn-sm btn-primary">Painel</a>
                    </Authorized>
                </AuthorizeView>
                <SessionStatusBadge />
            </div>
        </div>
    </header>

    <main class="flex-grow-1 container py-4">
        @Body
    </main>

    <footer class="portal-footer py-3 text-center text-muted small">
        &copy; @DateTime.UtcNow.Year TecFlow — integrado com TecFlow.Orquestrador
    </footer>
</div>

<LoadingOverlay />

<div id="blazor-error-ui" class="blazor-error-ui-custom">
    Ocorreu um erro inesperado.
    <a href="" class="reload">Recarregar</a>
    <button type="button" class="btn-close btn-close-white float-end" aria-label="Fechar"></button>
</div>
